# =============================================================================
# Web/Redis 独立容器单活配置（宿主机侧）
# 安装后默认路径：/etc/web-redis-ha/web-redis-ha.env
# =============================================================================

# 现有 PostgreSQL HA 容器名
PG_CONTAINER_NAME=postgres-ha

# 独立 Web / Redis 容器名
WEB_CONTAINER_NAME=web
REDIS_CONTAINER_NAME=redis

# Web 使用的 Redis DB。Web 启动前只清空该 DB，不执行 FLUSHALL。
WEB_REDIS_DB=0

# Redis 密码。现场 Redis 默认有密码时必须填写。
REDIS_PASSWORD=

# Web 健康检查地址。留空则跳过健康检查。
WEB_HEALTH_URL=http://127.0.0.1:8080/health
WEB_HEALTH_TIMEOUT=60
WEB_HEALTH_REQUEST_TIMEOUT=3

# 停止 Web 的等待时间
WEB_STOP_TIMEOUT=30

# agent 检查间隔
CHECK_INTERVAL_SECONDS=2

# PostgreSQL HA VIP 和端口
NODE_VIP=192.168.1.100
PG_PORT=5432

# 日志与锁
LOG_FILE=/var/log/web-redis-ha/web-redis-ha.log
LOCK_FILE=/var/run/web-redis-ha.lock
